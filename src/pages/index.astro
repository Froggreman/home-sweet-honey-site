---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home Sweet Honey — McKinney, TX" description="Raw, unfiltered wildflower honey and swarm removal services from McKinney, TX. Small-batch, local, and honest.">

  <!-- ░░░ NAV ░░░ -->
  <nav style="
    position: sticky; top: 0; z-index: 100;
    background: var(--green);
    padding: 0.9rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
  ">
    <span style="font-family:'Playfair Display',serif; color:var(--cream); font-size:1.1rem; letter-spacing:0.04em;">
      Home Sweet Honey
    </span>
    <div style="display:flex; gap:2rem;">
      <a href="#story"   style="color:var(--sage-light); font-size:0.9rem; letter-spacing:0.05em; text-transform:uppercase;">Our Story</a>
      <a href="#products" style="color:var(--sage-light); font-size:0.9rem; letter-spacing:0.05em; text-transform:uppercase;">Products</a>
      <a href="#swarm"   style="color:var(--sage-light); font-size:0.9rem; letter-spacing:0.05em; text-transform:uppercase;">Swarm Removal</a>
      <a href="#contact" style="color:var(--sage-light); font-size:0.9rem; letter-spacing:0.05em; text-transform:uppercase;">Contact</a>
    </div>
  </nav>

  <!-- ░░░ HERO ░░░ -->
  <header style="
    background: linear-gradient(160deg, var(--green) 0%, var(--green-mid) 60%, #4A7A4A 100%);
    padding: 6rem 1.5rem 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  ">
    <!-- Subtle botanical background texture via CSS -->
    <div style="
      position:absolute; inset:0;
      background-image: radial-gradient(ellipse at 20% 80%, rgba(143,168,130,0.15) 0%, transparent 60%),
                        radial-gradient(ellipse at 80% 20%, rgba(200,151,58,0.1) 0%, transparent 50%);
      pointer-events: none;
    "></div>

    <!-- Logo -->
    <div style="margin: 0 auto 2rem; max-width:220px; position:relative; z-index:1;">
      <img
        src="/Home Sweet Honey.png"
        alt="Home Sweet Honey logo"
        style="width:100%; filter: drop-shadow(0 4px 20px rgba(0,0,0,0.3));"
      />
    </div>

    <p style="
      color: var(--sage-light);
      font-size: 0.9rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    ">Raw · Unfiltered · Local</p>

    <h1 style="
      font-family: 'Playfair Display', serif;
      color: var(--cream);
      font-size: clamp(2.4rem, 6vw, 4rem);
      font-weight: 700;
      margin-bottom: 1.25rem;
      line-height: 1.15;
    ">
      Honey the Way<br/>It's Supposed to Be
    </h1>

    <p style="
      color: var(--sage-light);
      font-size: 1.1rem;
      max-width: 520px;
      margin: 0 auto 2.5rem;
      font-weight: 300;
    ">
      Small-batch wildflower honey from McKinney, Texas —
      straight from the hive, never over-processed.
    </p>

    <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
      <a href="#products" style="
        background: var(--gold);
        color: var(--green);
        padding: 0.85rem 2.2rem;
        font-family: 'Playfair Display', serif;
        font-weight: 600;
        font-size: 1rem;
        border-radius: 2px;
        letter-spacing: 0.03em;
        transition: background 0.2s;
      ">Our Honey</a>
      <a href="#contact" style="
        background: transparent;
        color: var(--cream);
        border: 1.5px solid var(--sage-light);
        padding: 0.85rem 2.2rem;
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        border-radius: 2px;
        letter-spacing: 0.03em;
      ">Get in Touch</a>
    </div>
  </header>

  <!-- ░░░ TRUST BAR ░░░ -->
  <div style="
    background: var(--gold);
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  ">
    {["🌸 Wildflower Honey", "🍯 Raw & Unfiltered", "📍 McKinney, TX", "🐝 Swarm Removal"].map(item => (
      <span style="color:var(--green); font-size:0.9rem; font-weight:700; letter-spacing:0.04em;">{item}</span>
    ))}
  </div>

  <!-- ░░░ STORY ░░░ -->
  <section id="story">
    <div class="container" style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">
      <div>
        <p style="color:var(--gold); font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Our Story</p>
        <h2 style="color:var(--green); font-size:clamp(2rem,4vw,2.8rem); margin-bottom:1.25rem;">
          From Backyard Hives<br/>to Your Table
        </h2>
        <div class="divider">✦ ✦ ✦</div>
        <p style="color:var(--text-soft); margin: 1.25rem 0; font-size:1.05rem;">
          Home Sweet Honey started the way most good things do — with curiosity, a little courage,
          and a deep respect for what bees have been doing for millions of years. We're a small
          family operation right here in McKinney, Texas, keeping bees the old-fashioned way.
        </p>
        <p style="color:var(--text-soft); font-size:1.05rem;">
          Our honey is raw and unfiltered — which means it keeps all its natural pollen, enzymes,
          and goodness intact. No heating, no over-processing. Just honey that actually tastes
          like where it came from.
        </p>
      </div>

      <!-- Story photos: hive exterior + honey harvest -->
      <div style="display:grid; grid-template-rows:1fr 1fr; gap:0.75rem; height:420px;">
        <img src="/photos/story-hive.jpg" alt="Beehive in the garden" style="width:100%;height:100%;object-fit:cover;border-radius:4px;" />
        <img src="/photos/honey-harvest.jpg" alt="Honey harvest" style="width:100%;height:100%;object-fit:cover;border-radius:4px;" />
      </div>
    </div>
  </section>

  <!-- ░░░ PRODUCTS ░░░ -->
  <section id="products">
    <div class="container" style="text-align:center;">
      <p style="color:var(--gold); font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">What We Make</p>
      <h2 style="color:var(--green); font-size:clamp(2rem,4vw,2.8rem); margin-bottom:0.5rem;">The Honey</h2>
      <div class="divider">✦ ✦ ✦</div>
      <p style="color:var(--text-soft); max-width:560px; margin:1rem auto 3rem; font-size:1.05rem;">
        Small-batch, seasonal, and always honest. Each jar is a little different —
        because the flowers are.
      </p>

      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:2rem; margin-top:1rem;">

        <!-- Product card 1 -->
        <div style="
          background: var(--cream);
          border: 1.5px solid var(--sage-light);
          border-radius: 4px;
          overflow: hidden;
          text-align: left;
          box-shadow: 0 2px 12px rgba(45,74,45,0.07);
        ">
          <div style="height:220px; overflow:hidden;">
            <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;">
              <source src="/videos/hero.mp4" type="video/mp4" />
            </video>
          </div>
          <div style="padding:1.5rem;">
            <h3 style="color:var(--green); font-size:1.3rem; margin-bottom:0.4rem;">Wildflower Honey</h3>
            <p style="color:var(--text-soft); font-size:0.95rem; line-height:1.6;">
              A rich, complex blend drawn from the wildflowers of North Texas. Notes vary by season —
              light and floral in spring, deeper and golden in late summer.
            </p>
            <p style="color:var(--gold); font-size:0.85rem; font-weight:700; margin-top:1rem; letter-spacing:0.05em;">RAW · UNFILTERED · 8 OZ</p>
          </div>
        </div>

        <!-- Product card 2 — placeholder for a second variety -->
        <div style="
          background: var(--cream);
          border: 1.5px dashed var(--sage);
          border-radius: 4px;
          overflow: hidden;
          text-align: left;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          padding: 2rem;
          min-height: 340px;
          color: var(--sage);
          gap: 0.5rem;
        ">
          <span style="font-size:2.5rem;">🌻</span>
          <p style="font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--green); text-align:center;">More varieties coming soon</p>
          <p style="font-size:0.85rem; text-align:center;">Check back — we add new products as the seasons allow.</p>
        </div>

      </div>

      <p style="color:var(--text-soft); margin-top:2.5rem; font-size:0.95rem;">
        Interested in purchasing?
        <a href="#contact" style="color:var(--green); font-weight:700; text-decoration:underline; text-underline-offset:3px;">Send us a message</a>
        and we'll let you know what's available.
      </p>
    </div>
  </section>

  <!-- ░░░ SWARM REMOVAL ░░░ -->
  <section id="swarm">
    <div class="container" style="display:grid; grid-template-columns:1fr 1fr; gap:4rem; align-items:center;">

      <!-- Swarm removal visual -->
      <div style="display:grid; grid-template-rows:1fr 1fr; gap:0.75rem; height:420px; order:2;">
        <img src="/photos/swarm-roof.jpg" alt="Bee swarm on roof" style="width:100%;height:100%;object-fit:cover;border-radius:4px;" />
        <img src="/photos/swarm-scene.jpg" alt="Swarm removal in progress" style="width:100%;height:100%;object-fit:cover;border-radius:4px;" />
      </div>

      <div style="order:1;">
        <p style="color:var(--gold); font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Services</p>
        <h2 style="color:var(--green); font-size:clamp(2rem,4vw,2.8rem); margin-bottom:1.25rem;">
          Swarm Removal
        </h2>
        <div class="divider" style="text-align:left;">✦ ✦ ✦</div>
        <p style="color:var(--text-soft); margin: 1.25rem 0; font-size:1.05rem;">
          Found a swarm on your property? Don't panic — and don't call an exterminator.
          Honeybee swarms are docile, temporary, and recoverable. We'll come out,
          safely remove the swarm, and relocate the colony to a good home.
        </p>
        <p style="color:var(--text-soft); font-size:1.05rem; margin-bottom:2rem;">
          We serve McKinney and the surrounding North Texas area. If you've got bees
          where they shouldn't be, reach out — we'd love to help.
        </p>

        <div style="
          background: var(--cream);
          border-left: 4px solid var(--gold);
          padding: 1.25rem 1.5rem;
          border-radius: 2px;
          display: flex;
          flex-direction: column;
          gap: 0.6rem;
          margin-bottom: 2rem;
        ">
          {[
            "Humane — bees are relocated, not killed",
            "Safe for your family and property",
            "Serving McKinney & North Texas",
            "Contact us for availability & pricing",
          ].map(item => (
            <div style="display:flex; gap:0.75rem; align-items:flex-start;">
              <span style="color:var(--gold); font-size:1rem; margin-top:0.1rem;">✓</span>
              <span style="color:var(--text-soft); font-size:0.95rem;">{item}</span>
            </div>
          ))}
        </div>

        <a href="#contact" style="
          display: inline-block;
          background: var(--green);
          color: var(--cream);
          padding: 0.85rem 2rem;
          font-family: 'Playfair Display', serif;
          font-size: 1rem;
          border-radius: 2px;
          letter-spacing: 0.03em;
        ">Request Swarm Removal</a>
      </div>
    </div>
  </section>

  <!-- ░░░ GALLERY ░░░ -->
  <section>
    <div class="container" style="text-align:center;">
      <p style="color:var(--gold); font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Behind the Scenes</p>
      <h2 style="color:var(--green); font-size:clamp(2rem,4vw,2.8rem); margin-bottom:0.5rem;">From the Hive</h2>
      <div class="divider">✦ ✦ ✦</div>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1rem; margin-top:2rem;">
        <video autoplay muted loop playsinline style="width:100%; aspect-ratio:9/16; object-fit:cover; border-radius:4px;">
          <source src="/videos/humble-beginnings-1.mp4" type="video/mp4" />
        </video>
        <video autoplay muted loop playsinline style="width:100%; aspect-ratio:9/16; object-fit:cover; border-radius:4px;">
          <source src="/videos/honey-harvest.mp4" type="video/mp4" />
        </video>
        <video autoplay muted loop playsinline style="width:100%; aspect-ratio:9/16; object-fit:cover; border-radius:4px;">
          <source src="/videos/swarm-1.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <!-- ░░░ CONTACT ░░░ -->
  <section id="contact">
    <div class="container" style="max-width:680px; text-align:center;">
      <p style="color:var(--gold); font-size:0.85rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Get in Touch</p>
      <h2 style="color:var(--green); font-size:clamp(2rem,4vw,2.8rem); margin-bottom:0.5rem;">Say Hello</h2>
      <div class="divider">✦ ✦ ✦</div>
      <p style="color:var(--text-soft); margin:1rem auto 2.5rem; font-size:1.05rem;">
        Whether you're interested in honey, need a swarm removed, or just want to talk bees —
        we'd love to hear from you.
      </p>

      <a href="mailto:samuelkaestner@gmail.com" style="
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        background: var(--green);
        color: var(--cream);
        padding: 1rem 2.5rem;
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        border-radius: 2px;
        letter-spacing: 0.03em;
        margin-bottom: 2rem;
        box-shadow: 0 4px 20px rgba(45,74,45,0.2);
      ">
        📬 samuelkaestner@gmail.com
      </a>

      <p style="color:var(--text-soft); font-size:0.95rem;">
        Based in <strong>McKinney, TX</strong> · Serving North Texas
      </p>
    </div>
  </section>

  <!-- ░░░ FOOTER ░░░ -->
  <footer style="
    background: var(--green);
    color: var(--sage-light);
    text-align: center;
    padding: 2.5rem 1.5rem;
    font-size: 0.9rem;
  ">
    <p style="font-family:'Playfair Display',serif; color:var(--cream); font-size:1.2rem; margin-bottom:0.5rem;">Home Sweet Honey</p>
    <p style="margin-bottom:0.3rem;">McKinney, Texas · Raw · Unfiltered · Local</p>
    <p style="margin-bottom:1rem;">
      <a href="mailto:samuelkaestner@gmail.com" style="color:var(--gold);">samuelkaestner@gmail.com</a>
    </p>
    <p style="color:var(--sage); font-size:0.8rem;">© {new Date().getFullYear()} Home Sweet Honey. All rights reserved.</p>
  </footer>

  <!-- Mobile nav fix -->
  <style>
    @media (max-width: 700px) {
      nav div { display: none; }
      section > .container[style*="grid-template-columns:1fr 1fr"] {
        grid-template-columns: 1fr !important;
      }
      #swarm .container > div[style*="order:2"] { order: 1 !important; }
      #swarm .container > div[style*="order:1"] { order: 2 !important; }
    }
  </style>

</Layout>
